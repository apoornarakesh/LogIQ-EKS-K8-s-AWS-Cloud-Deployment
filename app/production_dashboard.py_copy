"""
Production LogIQ Dashboard with AWS Metrics & Container Tracking
"""
from fastapi import FastAPI, WebSocket, Request
from fastapi.responses import HTMLResponse
from fastapi.middleware.cors import CORSMiddleware
import json
import asyncio
import random
import psutil
import subprocess
from datetime import datetime
from typing import Dict, Any
import os

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Store data
logs = []
connected_clients = []
streaming_active = True
aws_metrics_history = []

def get_docker_containers():
    """Get all running Docker containers with their details"""
    try:
        result = subprocess.run(['docker', 'ps', '--format', '{{.Names}}|{{.Image}}|{{.Status}}'], 
                              capture_output=True, text=True)
        containers = []
        for line in result.stdout.strip().split('\n'):
            if line:
                parts = line.split('|')
                containers.append({
                    'name': parts[0],
                    'image': parts[1] if len(parts) > 1 else 'unknown',
                    'status': parts[2] if len(parts) > 2 else 'running',
                    'type': 'docker'
                })
        return containers
    except:
        return []

def get_aws_metrics():
    """Get AWS/System metrics"""
    try:
        # CPU metrics
        cpu_percent = psutil.cpu_percent(interval=1)
        cpu_count = psutil.cpu_count()
        
        # Memory metrics
        memory = psutil.virtual_memory()
        
        # Disk metrics
        disk = psutil.disk_usage('/')
        
        # Network metrics
        network = psutil.net_io_counters()
        
        metrics = {
            'timestamp': datetime.now().isoformat(),
            'cpu': {
                'percent': cpu_percent,
                'count': cpu_count,
                'per_core': psutil.cpu_percent(interval=1, percpu=True)
            },
            'memory': {
                'total': memory.total,
                'available': memory.available,
                'percent': memory.percent,
                'used': memory.used,
                'free': memory.free
            },
            'disk': {
                'total': disk.total,
                'used': disk.used,
                'free': disk.free,
                'percent': disk.percent
            },
            'network': {
                'bytes_sent': network.bytes_sent,
                'bytes_recv': network.bytes_recv,
                'packets_sent': network.packets_sent,
                'packets_recv': network.packets_recv
            }
        }
        
        aws_metrics_history.append(metrics)
        if len(aws_metrics_history) > 60:  # Keep last 60 data points
            aws_metrics_history.pop(0)
        
        return metrics
    except Exception as e:
        print(f"Error getting metrics: {e}")
        return None

def generate_log_with_context():
    """Generate log with pod/container context"""
    containers = get_docker_containers()
    
    # If no containers found, create mock data
    if not containers:
        containers = [
            {'name': 'logiq-api-1', 'image': 'logiq/api:latest', 'status': 'Up 2 hours', 'type': 'docker'},
            {'name': 'logiq-worker-1', 'image': 'logiq/worker:latest', 'status': 'Up 2 hours', 'type': 'docker'},
            {'name': 'logiq-kafka-1', 'image': 'confluent/kafka:latest', 'status': 'Up 2 hours', 'type': 'docker'},
            {'name': 'logiq-postgres-1', 'image': 'postgres:15', 'status': 'Up 2 hours', 'type': 'docker'},
        ]
    
    container = random.choice(containers)
    
    log_levels = ['INFO', 'WARNING', 'ERROR', 'DEBUG', 'CRITICAL']
    services = ['api', 'worker', 'kafka', 'postgres', 'redis', 'elasticsearch']
    error_types = [
        'Connection refused', 'Timeout', 'Authentication failed', 
        'Resource exhausted', 'Rate limit exceeded', 'Database deadlock',
        'Network partition', 'Disk full', 'Memory limit exceeded'
    ]
    
    # Weighted severity
    rand = random.random()
    if rand < 0.6:
        level = 'INFO'
    elif rand < 0.8:
        level = 'WARNING'
    elif rand < 0.95:
        level = 'ERROR'
    else:
        level = 'CRITICAL'
    
    messages = {
        'INFO': [
            f"Container {container['name']} started successfully",
            f"Health check passed for {container['name']}",
            f"Successfully connected to database",
            f"Processed 1000 requests",
            f"Cache warmed up for service"
        ],
        'WARNING': [
            f"High latency detected in {container['name']}",
            f"Memory usage above 80% in {container['name']}",
            f"Slow query detected (2.5s)",
            f"Retrying connection to database (attempt 3)",
            f"Rate limit approaching threshold"
        ],
        'ERROR': [
            f"Connection failed from {container['name']} to database",
            f"Timeout processing request in {container['name']}",
            f"{random.choice(error_types)} in {container['name']}",
            f"Failed to write to log storage",
            f"Unhandled exception in worker thread"
        ],
        'CRITICAL': [
            f"CRITICAL: {container['name']} is unhealthy - restarting",
            f"Data corruption detected in {container['name']}",
            f"Complete service outage in {container['name']} zone",
            f"Security breach detected from IP 192.168.1.{random.randint(1,255)}"
        ],
        'DEBUG': [
            f"Debug: Processing request ID req_{random.randint(1000,9999)}",
            f"Debug: Cache key miss for user_{random.randint(1,100)}",
            f"Debug: Query plan generated in 5ms"
        ]
    }
    
    return {
        "timestamp": datetime.now().isoformat(),
        "level": level,
        "source": random.choice(services),
        "container": container['name'],
        "container_image": container['image'],
        "container_status": container['status'],
        "message": random.choice(messages.get(level, messages['INFO'])),
        "trace_id": f"trace_{random.randint(10000, 99999)}",
        "pod_id": f"pod-{random.randint(1,10)}",
        "namespace": "production",
        "region": "us-east-1"
    }

async def broadcast_to_clients(data):
    """Broadcast data to all connected WebSocket clients"""
    message = json.dumps(data)
    for client in connected_clients[:]:
        try:
            await client.send_text(message)
        except:
            if client in connected_clients:
                connected_clients.remove(client)

async def metrics_generator():
    """Generate and broadcast AWS metrics"""
    while True:
        if connected_clients:
            metrics = get_aws_metrics()
            if metrics:
                await broadcast_to_clients({
                    "type": "metrics",
                    "data": metrics
                })
        await asyncio.sleep(5)  # Update every 5 seconds

async def log_generator():
    """Generate and broadcast logs"""
    global streaming_active
    while True:
        if streaming_active and connected_clients:
            log = generate_log_with_context()
            logs.insert(0, log)
            if len(logs) > 500:
                logs.pop()
            await broadcast_to_clients({
                "type": "log",
                "data": log
            })
        await asyncio.sleep(0.5)  # 2 logs per second

@app.on_event("startup")
async def startup_event():
    """Start background tasks"""
    print("\n" + "=" * 60)
    print("🚀 Production LogIQ Dashboard Started")
    print("=" * 60)
    print("\n📊 Dashboard URL: http://localhost:8000")
    print("📡 Features:")
    print("   • Container/Pod tracking")
    print("   • AWS/System metrics")
    print("   • Real-time log streaming")
    print("   • Stop/Start controls")
    print("\n" + "=" * 60 + "\n")
    
    asyncio.create_task(log_generator())
    asyncio.create_task(metrics_generator())

@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    connected_clients.append(websocket)
    
    # Send recent logs
    for log in logs[-100:]:
        await websocket.send_text(json.dumps({"type": "log", "data": log}))
    
    try:
        while True:
            data = await websocket.receive_text()
            msg = json.loads(data)
            if msg.get('action') == 'stop':
                global streaming_active
                streaming_active = False
                await websocket.send_text(json.dumps({"type": "control", "status": "stopped"}))
            elif msg.get('action') == 'start':
                streaming_active = True
                await websocket.send_text(json.dumps({"type": "control", "status": "started"}))
            elif msg.get('action') == 'clear':
                logs.clear()
                await websocket.send_text(json.dumps({"type": "control", "status": "cleared"}))
    except:
        if websocket in connected_clients:
            connected_clients.remove(websocket)


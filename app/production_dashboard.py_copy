    </style>
</head>
<body>
    <div class="dashboard">
        <!-- Main Content -->
        <div class="main-content">
            <div class="header">
                <h1>📊 LogIQ Production Dashboard</h1>
                <p style="margin-top: 5px; opacity: 0.8;">Container Tracking | AWS Metrics | Real-time Logs</p>
            </div>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value" id="totalLogs">0</div>
                    <div class="stat-label">Total Logs</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="errorCount">0</div>
                    <div class="stat-label">Errors</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="logsPerMin">0</div>
                    <div class="stat-label">Logs/Minute</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="activeContainers">0</div>
                    <div class="stat-label">Active Containers</div>
                </div>
            </div>
            
            <div class="metrics-section">
                <h3>📈 AWS/System Metrics</h3>
                <div class="metrics-grid">
                    <div class="metric">
                        <div class="metric-value" id="cpuMetric">0%</div>
                        <div class="metric-label">CPU Usage</div>
                    </div>
                    <div class="metric">
                        <div class="metric-value" id="memoryMetric">0%</div>
                        <div class="metric-label">Memory Usage</div>
                    </div>
                    <div class="metric">
                        <div class="metric-value" id="diskMetric">0%</div>
                        <div class="metric-label">Disk Usage</div>
                    </div>
                    <div class="metric">
                        <div class="metric-value" id="networkMetric">0 MB/s</div>
                        <div class="metric-label">Network I/O</div>
                    </div>
                </div>
            </div>
            
            <div class="logs-section">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                    <h3>📋 Log History</h3>
                    <div>
                        <button class="filter-btn active" onclick="setFilter('ALL')">ALL</button>
                        <button class="filter-btn" onclick="setFilter('ERROR')">ERROR</button>
                        <button class="filter-btn" onclick="setFilter('WARNING')">WARNING</button>
                        <button class="filter-btn" onclick="setFilter('INFO')">INFO</button>
                    </div>
                </div>
                <div class="logs-table" id="logsTable">
                    <div style="text-align: center; padding: 40px;">Loading logs...</div>
                </div>
                <div class="controls">
                    <button class="btn-stop" onclick="stopStreaming()">⏹ Stop Streaming</button>
                    <button class="btn-start" onclick="startStreaming()">▶ Start Streaming</button>
                    <button class="btn-clear" onclick="clearLogs()">🗑 Clear All</button>
                </div>
            </div>
        </div>
        
        <!-- Sidebar - Live Streaming -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h3>🔴 LIVE STREAM</h3>
                <p style="font-size: 11px; color: #888;">Real-time container logs</p>
            </div>
            <div class="live-stream" id="liveStream">
                <div style="text-align: center; padding: 20px; color: #888;">Waiting for logs...</div>
            </div>
        </div>
    </div>
    
    <script>
        let ws = null;
        let currentFilter = 'ALL';
        let logs = [];
        let logTimes = [];
        let streamingEnabled = true;
        
        function connect() {
            ws = new WebSocket('ws://localhost:8000/ws');
            ws.onopen = () => console.log('✅ Connected');
            ws.onmessage = (e) => {
                const data = JSON.parse(e.data);
                if (data.type === 'log') {
                    if (streamingEnabled) addLog(data.data);
                } else if (data.type === 'metrics') {
                    updateMetrics(data.data);
                } else if (data.type === 'control') {
                    console.log('Control:', data.status);
                }
            };
            ws.onclose = () => setTimeout(connect, 3000);
        }
        
        function addLog(log) {
            logs.unshift(log);
            if (logs.length > 500) logs.pop();
            
            logTimes.push(Date.now());
            logTimes = logTimes.filter(t => Date.now() - t < 60000);
            
            updateDisplay();
            addToLiveStream(log);
        }
        
        function addToLiveStream(log) {
            const stream = document.getElementById('liveStream');
            const streamItem = document.createElement('div');
            streamItem.className = 'stream-item';
            streamItem.style.borderLeftColor = getSeverityColor(log.level);
            streamItem.innerHTML = `
                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                    <span style="font-size: 10px; color: #888;">${new Date(log.timestamp).toLocaleTimeString()}</span>
                    <span class="severity severity-${log.level}" style="font-size: 8px;">${log.level}</span>
                </div>
                <div style="font-size: 11px;"><strong>${log.container}</strong> [${log.source}]</div>
                <div style="font-size: 10px; margin-top: 5px;">${log.message}</div>
            `;
            stream.insertBefore(streamItem, stream.firstChild);
            if (stream.children.length > 50) stream.removeChild(stream.lastChild);
        }
        
        function updateDisplay() {
            const filtered = currentFilter === 'ALL' ? logs : logs.filter(l => l.level === currentFilter);
            const container = document.getElementById('logsTable');
            
            if (filtered.length === 0) {
                container.innerHTML = '<div style="text-align:center;padding:40px;">No logs</div>';
                return;
            }
            
            let html = '<table><thead><tr><th>Time</th><th>Severity</th><th>Container</th><th>Source</th><th>Message</th></tr></thead><tbody>';
            filtered.slice(0, 100).forEach(log => {
                html += `<tr>
                    <td style="white-space:nowrap;">${new Date(log.timestamp).toLocaleTimeString()}</td>
                    <td><span class="severity severity-${log.level}">${log.level}</span></td>
                    <td><code style="font-size: 10px;">${log.container}</code></td>
                    <td>${log.source}</td>
                    <td style="word-break:break-word;">${log.message}</td>
                </tr>`;
            });
            html += '</tbody></table>';
            container.innerHTML = html;
            
            document.getElementById('totalLogs').innerText = logs.length;
            document.getElementById('errorCount').innerText = logs.filter(l => l.level === 'ERROR' || l.level === 'CRITICAL').length;
            document.getElementById('logsPerMin').innerText = logTimes.length;
            
            const containers = new Set(logs.map(l => l.container));
            document.getElementById('activeContainers').innerText = containers.size;
        }
        
        function updateMetrics(metrics) {
            if (metrics.cpu) document.getElementById('cpuMetric').innerText = `${metrics.cpu.percent}%`;
            if (metrics.memory) document.getElementById('memoryMetric').innerText = `${metrics.memory.percent}%`;
            if (metrics.disk) document.getElementById('diskMetric').innerText = `${metrics.disk.percent}%`;
            
            const netMBps = ((metrics.network?.bytes_sent + metrics.network?.bytes_recv) / 1024 / 1024).toFixed(1);
            document.getElementById('networkMetric').innerText = `${netMBps} MB/s`;
        }
        
        function getSeverityColor(level) {
            const colors = { ERROR: '#dc2626', CRITICAL: '#991b1b', WARNING: '#f59e0b', INFO: '#10b981', DEBUG: '#8b5cf6' };
            return colors[level] || '#667eea';
        }
        
        function setFilter(level) {
            currentFilter = level;
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            updateDisplay();
        }
        
        function stopStreaming() {
            streamingEnabled = false;
            if (ws && ws.readyState === WebSocket.OPEN) {
                ws.send(JSON.stringify({action: 'stop'}));
            }
        }
        
        function startStreaming() {
            streamingEnabled = true;
            if (ws && ws.readyState === WebSocket.OPEN) {
                ws.send(JSON.stringify({action: 'start'}));
            }
        }
        
        function clearLogs() {
            logs = [];
            logTimes = [];
            updateDisplay();
            if (ws && ws.readyState === WebSocket.OPEN) {
                ws.send(JSON.stringify({action: 'clear'}));
            }
        }
        
        connect();
    </script>
</body>
</html>
"""

@app.get("/")
@app.get("/dashboard")
async def root():
    return HTMLResponse(HTML)

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
